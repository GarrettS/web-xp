#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
ROLE_FILE="${SMUX_ROLE_FILE:-${HOME}/.web-xp/smux/roles.tsv}"

usage() {
  cat <<EOF
Usage:
  tmux-bridge list
  tmux-bridge register <role> <pane-id>
  tmux-bridge roles
  tmux-bridge notify <role|pane-id> <message>
  tmux-bridge paste <role|pane-id> <text>
  tmux-bridge handoff <codex|claude> [note]
  tmux-bridge escalate <from-role> <message>

Environment:
  SMUX_ROLE_FILE   Override role registry path

Notes:
  - Roles are stored outside the repo by default: ~/.web-xp/smux/roles.tsv
  - 'handoff' pastes a standard inbox-check prompt and auto-sends it.
  - 'escalate' notifies the human pane with the requesting agent's identity.
  - Register human pane: tmux-bridge register human %0
EOF
}

require_tmux() {
  if ! command -v tmux >/dev/null 2>&1; then
    echo "tmux-bridge: tmux is required" >&2
    exit 1
  fi
}

ensure_role_dir() {
  mkdir -p "$(dirname "$ROLE_FILE")"
}

valid_role() {
  case "$1" in
    codex|claude|human)
      return 0
      ;;
    *)
      echo "tmux-bridge: unsupported role '$1' (expected codex, claude, or human)" >&2
      exit 1
      ;;
  esac
}

resolve_target() {
  local target="$1"

  if [[ "$target" == %* ]]; then
    printf '%s\n' "$target"
    return
  fi

  if [ ! -f "$ROLE_FILE" ]; then
    echo "tmux-bridge: role file not found: $ROLE_FILE" >&2
    exit 1
  fi

  local pane_id
  pane_id="$(awk -F '\t' -v role="$target" '$1 == role { print $2; exit }' "$ROLE_FILE")"

  if [ -z "$pane_id" ]; then
    echo "tmux-bridge: role '$target' is not registered" >&2
    exit 1
  fi

  printf '%s\n' "$pane_id"
}

build_handoff_prompt() {
  local role="$1"
  local note="${2:-}"
  local prompt

  case "$role" in
    codex)
      prompt="Read ${REPO_ROOT}/agent-handoff/claude-to-codex.md and continue from there."
      ;;
    claude)
      prompt="Read ${REPO_ROOT}/agent-handoff/codex-to-claude.md, act on it, and restart the poll."
      ;;
    *)
      echo "tmux-bridge: unsupported handoff role '$role'" >&2
      exit 1
      ;;
  esac

  if [ -n "$note" ]; then
    prompt="${prompt} ${note}"
  fi

  printf '%s\n' "$prompt"
}

cmd="${1:-}"

case "$cmd" in
  list)
    require_tmux
    tmux list-panes -a -F 'session=#{session_name} window=#{window_index} pane=#{pane_id} title=#{pane_title} cmd=#{pane_current_command}'
    ;;

  register)
    require_tmux
    role="${2:-}"
    pane_id="${3:-}"
    if [ -z "$role" ] || [ -z "$pane_id" ]; then
      usage
      exit 1
    fi
    valid_role "$role"
    tmux list-panes -a -F '#{pane_id}' | grep -Fx "$pane_id" >/dev/null
    ensure_role_dir
    tmp_file="$(mktemp)"
    if [ -f "$ROLE_FILE" ]; then
      awk -F '\t' -v role="$role" '$1 != role { print $1 "\t" $2 }' "$ROLE_FILE" > "$tmp_file"
    fi
    printf '%s\t%s\n' "$role" "$pane_id" >> "$tmp_file"
    mv "$tmp_file" "$ROLE_FILE"
    echo "registered $role -> $pane_id"
    ;;

  roles)
    if [ ! -f "$ROLE_FILE" ]; then
      echo "no roles registered"
      exit 0
    fi
    cat "$ROLE_FILE"
    ;;

  notify)
    require_tmux
    target="${2:-}"
    shift 2 || true
    message="${*:-}"
    if [ -z "$target" ] || [ -z "$message" ]; then
      usage
      exit 1
    fi
    pane_id="$(resolve_target "$target")"
    tmux display-message -t "$pane_id" "$message"
    ;;

  paste)
    require_tmux
    target="${2:-}"
    shift 2 || true
    text="${*:-}"
    if [ -z "$target" ] || [ -z "$text" ]; then
      usage
      exit 1
    fi
    pane_id="$(resolve_target "$target")"
    tmux set-buffer -- "$text"
    tmux paste-buffer -d -t "$pane_id"
    ;;

  handoff)
    require_tmux
    role="${2:-}"
    shift 2 || true
    note="${*:-}"
    if [ -z "$role" ]; then
      usage
      exit 1
    fi
    valid_role "$role"
    pane_id="$(resolve_target "$role")"
    prompt="$(build_handoff_prompt "$role" "$note")"
    tmux display-message -t "$pane_id" "smux handoff ready for $role"
    tmux set-buffer -- "$prompt"
    tmux paste-buffer -d -t "$pane_id"
    tmux send-keys -t "$pane_id" Enter
    ;;

  escalate)
    require_tmux
    from_role="${2:-}"
    shift 2 || true
    message="${*:-needs human attention}"
    if [ -z "$from_role" ]; then
      echo "Usage: tmux-bridge escalate <from-role> <message>" >&2
      exit 1
    fi
    human_pane="$(resolve_target "human")"
    display_msg="[$from_role] $message"
    # Notify human pane
    tmux display-message -t "$human_pane" "$display_msg"
    # Terminal bell in human pane
    tmux send-keys -t "$human_pane" "printf '\\a'" Enter
    # macOS notification
    if command -v osascript >/dev/null 2>&1; then
      safe_message="${display_msg//\"/\\\"}"
      osascript -e "display notification \"$safe_message\" with title \"smux: human needed\" sound name \"Glass\"" 2>/dev/null || true
    fi
    echo "ESCALATE: $display_msg"
    ;;

  ""|-h|--help|help)
    usage
    ;;

  *)
    echo "tmux-bridge: unknown command '$cmd'" >&2
    usage
    exit 1
    ;;
esac
